{
  "microservices": {
    "workspace": {
      "NLog": {
        "internalLogLevel": "Info",
        "internalLogFile": "${environment:ARCON_CI_CONFIG_PATH:whenEmpty=Log}/Mircoservice_InternalLog/Workspace/nlog.txt",
        "extensions": [
          {
            "assembly": "NLog.Extensions.Logging"
          },
          {
            "assembly": "NLog.Web.AspNetCore"
          }
        ],
        "targets": {
          "allfile": {
            "type": "File",
            "fileName": "${environment:ARCON_CI_CONFIG_PATH:whenEmpty=Logs}/Microservice_Logs/Workspace/${shortdate}.txt",
            "layout": "${longdate} | ${uppercase:${level}} | ClassName : ${logger} | MethodName : ${callsite} | LineNo : ${callsite-linenumber} | Message : ${message} ${exception:format=tostring}",
            "maxArchiveDays": 5
          }
        },
        "rules": [
          {
            "logger": "*",
            "minLevel": "Error",
            "writeTo": "allfile"
          }
        ]
      }
    },
